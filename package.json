{
  "name": "nemoclaw-demo",
  "version": "0.1.0",
  "description": "Multi-agent financial services support demo running inside NemoClaw sandboxes",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/dev-server.ts",
    "orchestrator": "ts-node src/dev-server.ts",
    "agent": "ts-node src/agent-server.ts",
    "agent:triage": "AGENT_ROLE=triage AGENT_PORT=8081 ts-node src/agent-server.ts",
    "agent:billing": "AGENT_ROLE=billing AGENT_PORT=8082 ts-node src/agent-server.ts",
    "agent:compliance": "AGENT_ROLE=compliance AGENT_PORT=8083 ts-node src/agent-server.ts",
    "agent:technical": "AGENT_ROLE=technical AGENT_PORT=8084 ts-node src/agent-server.ts",
    "agent:pricing": "AGENT_ROLE=pricing AGENT_PORT=8085 ts-node src/agent-server.ts",
    "agent:claims": "AGENT_ROLE=claims_analyst AGENT_PORT=8086 ts-node src/agent-server.ts",
    "agents:local": "concurrently -n triage,billing,compliance,technical,pricing,claims -c blue,green,yellow,magenta,cyan,red \"npm:agent:triage\" \"npm:agent:billing\" \"npm:agent:compliance\" \"npm:agent:technical\" \"npm:agent:pricing\" \"npm:agent:claims\"",
    "lint": "eslint src/ tests/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:security": "jest tests/security"
  },
  "keywords": [
    "nemoclaw",
    "agentic-ai",
    "security",
    "sandbox"
  ],
  "author": "Paul Clement <paul.clement.lamotte@gmail.com>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.18.0",
    "openai": "^4.50.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
