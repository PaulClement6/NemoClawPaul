{
  "models": {
    "mode": "merge",
    "providers": {
      "inference": {
        "baseUrl": "https://inference.local/v1",
        "apiKey": "unused",
        "api": "openai-responses",
        "models": [
          {
            "id": "nvidia/nemotron-3-super-120b-a12b",
            "name": "inference/nvidia/nemotron-3-super-120b-a12b",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 131072,
            "maxTokens": 4096,
            "api": "openai-responses"
          }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": {
      "token": "meridian-demo-2026"
    },
    "controlUi": {
      "enabled": true,
      "allowedOrigins": ["http://127.0.0.1:18789"],
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    },
    "trustedProxies": ["127.0.0.1", "::1"],
    "http": {
      "endpoints": {
        "chatCompletions": { "enabled": true },
        "responses": { "enabled": true }
      }
    }
  },
  "skills": {
    "load": {
      "extraDirs": ["/sandbox/.openclaw-data/skills"]
    }
  },
  "canvasHost": {
    "root": "/sandbox/.openclaw-data/canvas",
    "liveReload": true
  },
  "agents": {
    "defaults": {
      "workspace": "/sandbox/.openclaw-data/workspace/meridian",
      "model": {
        "primary": "inference/nvidia/nemotron-3-super-120b-a12b",
        "fallbacks": []
      },
      "skipBootstrap": false,
      "userTimezone": "Europe/London",
      "timeFormat": "24",
      "thinkingDefault": "off",
      "timeoutSeconds": 120,
      "maxConcurrent": 3,
      "sandbox": {
        "mode": "all",
        "scope": "agent",
        "workspaceAccess": "ro"
      },
      "compaction": {
        "mode": "safeguard",
        "keepRecentTokens": 30000
      },
      "heartbeat": {
        "every": "0m"
      }
    },
    "list": [
      {
        "id": "triage",
        "default": true,
        "name": "Triage Agent",
        "workspace": "/sandbox/.openclaw-data/workspace/triage",
        "identity": {
          "name": "Meridian Support",
          "emoji": "🏠",
          "theme": "professional UK insurance customer support front-desk"
        },
        "skills": ["meridian-triage"],
        "tools": {
          "profile": "minimal",
          "alsoAllow": [
            "read",
            "sessions_spawn",
            "sessions_send",
            "session_status",
            "memory_search",
            "subagents",
            "agents_list"
          ],
          "deny": [
            "write", "edit", "exec", "process",
            "browser", "canvas", "cron", "nodes", "apply_patch"
          ]
        },
        "subagents": {
          "allowAgents": ["billing", "compliance", "technical", "pricing", "claims_analyst"]
        }
      },
      {
        "id": "billing",
        "name": "Billing Specialist",
        "workspace": "/sandbox/.openclaw-data/workspace/billing",
        "identity": {
          "name": "Billing",
          "emoji": "💷",
          "theme": "meticulous UK insurance billing specialist"
        },
        "skills": ["meridian-billing"],
        "tools": {
          "profile": "minimal",
          "alsoAllow": ["read", "memory_search", "sessions_send", "session_status"],
          "deny": [
            "write", "edit", "exec", "process",
            "browser", "canvas", "cron", "nodes", "apply_patch", "sessions_spawn"
          ]
        },
        "subagents": {
          "allowAgents": []
        }
      },
      {
        "id": "compliance",
        "name": "Compliance Officer",
        "workspace": "/sandbox/.openclaw-data/workspace/compliance",
        "identity": {
          "name": "Compliance",
          "emoji": "🔒",
          "theme": "careful UK insurance compliance and data protection officer"
        },
        "skills": ["meridian-compliance"],
        "tools": {
          "profile": "minimal",
          "alsoAllow": ["read", "memory_search", "sessions_send", "session_status"],
          "deny": [
            "write", "edit", "exec", "process",
            "browser", "canvas", "cron", "nodes", "apply_patch", "sessions_spawn"
          ]
        },
        "subagents": {
          "allowAgents": []
        }
      },
      {
        "id": "technical",
        "name": "Technical Support",
        "workspace": "/sandbox/.openclaw-data/workspace/technical",
        "identity": {
          "name": "Tech Support",
          "emoji": "🔧",
          "theme": "helpful UK insurance technical support specialist"
        },
        "skills": ["meridian-technical"],
        "tools": {
          "profile": "minimal",
          "alsoAllow": ["read", "memory_search", "sessions_send", "session_status"],
          "deny": [
            "write", "edit", "exec", "process",
            "browser", "canvas", "cron", "nodes", "apply_patch", "sessions_spawn"
          ]
        },
        "subagents": {
          "allowAgents": []
        }
      },
      {
        "id": "pricing",
        "name": "Pricing Specialist",
        "workspace": "/sandbox/.openclaw-data/workspace/pricing",
        "identity": {
          "name": "Pricing",
          "emoji": "📊",
          "theme": "analytical UK insurance pricing and quotes specialist"
        },
        "skills": ["meridian-pricing"],
        "tools": {
          "profile": "minimal",
          "alsoAllow": ["read", "memory_search", "sessions_send", "session_status"],
          "deny": [
            "write", "edit", "exec", "process",
            "browser", "canvas", "cron", "nodes", "apply_patch", "sessions_spawn"
          ]
        },
        "subagents": {
          "allowAgents": []
        }
      },
      {
        "id": "claims_analyst",
        "name": "Claims Analyst",
        "workspace": "/sandbox/.openclaw-data/workspace/claims_analyst",
        "identity": {
          "name": "Claims",
          "emoji": "📋",
          "theme": "thorough UK insurance claims investigation analyst"
        },
        "skills": ["meridian-claims"],
        "tools": {
          "profile": "minimal",
          "alsoAllow": ["read", "memory_search", "sessions_send", "session_status"],
          "deny": [
            "write", "edit", "exec", "process",
            "browser", "canvas", "cron", "nodes", "apply_patch", "sessions_spawn"
          ]
        },
        "subagents": {
          "allowAgents": []
        }
      }
    ]
  },
  "session": {
    "scope": "per-sender",
    "reset": {
      "mode": "idle",
      "idleMinutes": 30
    }
  },
  "plugins": {
    "entries": {
      "openshell": {
        "enabled": true,
        "config": {
          "mode": "remote",
          "policy": "strict",
          "autoProviders": true,
          "timeoutSeconds": 60
        }
      }
    }
  },
  "tools": {
    "sandbox": {
      "tools": {
        "allow": [
          "read", "memory_search",
          "sessions_list", "sessions_history",
          "sessions_send", "sessions_spawn", "session_status"
        ],
        "deny": [
          "write", "edit", "apply_patch", "exec", "process",
          "browser", "canvas", "cron", "nodes",
          "gateway", "image", "image_generate", "video_generate", "tts"
        ]
      }
    }
  },
  "messages": {
    "groupChat": {
      "mentionPatterns": ["@meridian", "@support"]
    }
  }
}
