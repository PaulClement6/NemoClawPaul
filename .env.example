# =============================================================================
# NemoClaw Demo — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- LLM Configuration ---
# Get your API key from https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use (check https://build.nvidia.com for current catalog)
# Options:
#   meta/llama-3.1-70b-instruct
#   meta/llama-3.1-405b-instruct
#   mistralai/mixtral-8x22b-instruct-v0.1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# NVIDIA NIM endpoint (OpenAI-compatible)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Server ---
PORT=3000
NODE_ENV=development

# --- NemoClaw Sandbox ---
# Set to "true" when running inside openshell on Brev
# When false, policy switches are logged but not executed
NEMOCLAW_ENABLED=false

# Directory containing sandbox policy YAML files
NEMOCLAW_POLICY_DIR=./policies

# Log level for NemoClaw events (debug, info, warn, error)
NEMOCLAW_LOG_LEVEL=info

# --- Agentic Loop ---
# Maximum number of tool-call iterations before forcing a response
MAX_TOOL_ITERATIONS=10
